# -------------------------------
# OpenClaw Company Kit
# -------------------------------

# Use an isolated OpenClaw profile for this kit.
OPENCLAW_PROFILE=company

# Optional: source config for bootstrap (default: openclaw config file)
SOURCE_OPENCLAW_CONFIG=~/.openclaw/openclaw.json

# Company/project metadata
COMPANY_NAME=OpenClaw Company
PROJECT_PATH=/path/to/your-project
PROJECT_REPO=your-org/your-repo

# Feishu group routing
GROUP_ID=oc_replace_with_group_id

# Feishu mapping note:
# - 7 role agents are internal agents
# - default external Feishu accounts are 2 apps:
#   1) hot-search (group router + cron delivery)
#   2) ai-tech (optional intel account)

# Feishu account 1 (required): group routing + cron delivery
FEISHU_HOT_ACCOUNT_ID=hot-search
FEISHU_HOT_BOT_NAME=小龙虾 1 号
FEISHU_HOT_APP_ID=cli_replace_hot_app_id
FEISHU_HOT_APP_SECRET=replace_hot_app_secret

# Feishu account 2 (optional): project-intel account
FEISHU_AI_ACCOUNT_ID=ai-tech
FEISHU_AI_BOT_NAME=小龙虾 2 号
FEISHU_AI_APP_ID=
FEISHU_AI_APP_SECRET=

# Optional: GitHub token for gh-issues skill
GH_TOKEN=

# Optional: model override (keep empty to preserve source config model)
MODEL_PRIMARY=

# Dashboard service
DASHBOARD_PORT=8788
