# -------------------------------
# OpenClaw Company Kit
# -------------------------------

# Use an isolated OpenClaw profile for this kit.
OPENCLAW_PROFILE=company

# Optional: source config for bootstrap (default: openclaw config file)
SOURCE_OPENCLAW_CONFIG=~/.openclaw/openclaw.json

# Company/project metadata
COMPANY_NAME=OpenClaw Company
PROJECT_PATH=/path/to/your-project
PROJECT_REPO=your-org/your-repo
# Workflow package: default | requirement-review | bugfix | release-retro
WORKFLOW_TEMPLATE=default

# Feishu group routing
GROUP_ID=oc_replace_with_group_id

# Feishu mapping note:
# - 7 role agents are internal agents
# - default external Feishu account is a single app: ai-tech
# - hot-search fields are kept for backward compatibility (optional)

# Feishu account (required): group routing + cron delivery
FEISHU_AI_ACCOUNT_ID=ai-tech
FEISHU_AI_BOT_NAME=小龙虾 2 号
FEISHU_AI_APP_ID=cli_replace_ai_app_id
FEISHU_AI_APP_SECRET=replace_ai_app_secret

# Legacy compatibility fields (optional; usually leave empty)
FEISHU_HOT_ACCOUNT_ID=
FEISHU_HOT_BOT_NAME=
FEISHU_HOT_APP_ID=
FEISHU_HOT_APP_SECRET=
# Optional: comma-separated allowlist for incoming sender IDs.
# Empty means secure default: only GROUP_ID is allowed.
# Example: FEISHU_ALLOW_FROM=oc_xxx,oc_yyy
FEISHU_ALLOW_FROM=

# Optional: GitHub token for gh-issues skill
GH_TOKEN=

# Optional: model override (keep empty to preserve source config model)
MODEL_PRIMARY=

# Custom model provider (used when MODEL_PRESET=custom or preset with self-hosted endpoint)
CUSTOM_BASE_URL=
CUSTOM_API_KEY=
CUSTOM_MODEL_ID=
CUSTOM_PROVIDER_ID=
CUSTOM_COMPATIBILITY=

# Dashboard service
DASHBOARD_PORT=8788

# Optional: per-role model override (keep empty to use MODEL_PRIMARY)
# MODEL_SENIOR_DEV=
# MODEL_REVIEWER=
# MODEL_GROWTH=

# Heartbeat interval for rd-company (default: 30m)
# HEARTBEAT_INTERVAL=30m

# Dashboard/issue-sync refresh interval in seconds (default: 300)
# REFRESH_INTERVAL=300

# Dependency preflight override (default requires Node >= 22)
# OPENCLAW_NODE_MIN_MAJOR=22
# Optional: allow startup without gh CLI (GitHub sync capabilities will be degraded)
# OPENCLAW_ALLOW_NO_GH=1
# Optional: auto-deploy gh bridge script to PROJECT_PATH during install
# SYNC_PROJECT_GH_BRIDGE=1
# Optional: make install fail if bridge deploy fails
# SYNC_PROJECT_GH_BRIDGE_STRICT=0
# Optional: auto-deploy gh bridge during launch (default off to avoid pre-config writes)
# SYNC_PROJECT_GH_BRIDGE_ON_LAUNCH=0

# Orchestration engine toggle (0=off, legacy cron execution; 1=on, tasks routed through engine)
# ORCHESTRATOR_ENABLED=0

# Health SLA / watchdog (optional)
# DASHBOARD_DATA_SLA_MINUTES=15
# WATCHDOG_ALERT_THROTTLE_SEC=600

# issue-sync customization (optional)
# SPRINT_LABEL=sprint:w11
# SPRINT_NAME=W11 冲刺
# MILESTONE_TITLE=MVP Sprint W11
# MILESTONE_DUE=2026-03-31T00:00:00Z
# MILESTONE_DESC=MVP 冲刺周：核心稳定性、安全与增长基础能力
# CRON_GUARD_TARGET_JOB_ID=
# CRON_PIPELINE_TECH_JOB_ID=
# CRON_PIPELINE_PRODUCT_JOB_ID=
# CRON_PIPELINE_REVIEWER_JOB_ID=
# CRON_PIPELINE_QA_JOB_ID=

# dashboard GitHub data cache / budget (optional)
# OPENCLAW_GITHUB_TRACKER_CACHE_TTL_SEC=300
# OPENCLAW_GITHUB_ISSUE_SCHEDULE_CACHE_TTL_SEC=600
# OPENCLAW_GITHUB_ISSUE_EVIDENCE_CACHE_TTL_SEC=1800
# OPENCLAW_GITHUB_API_BUDGET=80

# backup options (optional)
# BACKUP_INCLUDE_TASK_SUMMARY=1
# BACKUP_TASK_SUMMARY_DAYS=7

# Recommended: Bearer token for control_server.py API auth.
# If unset, control_server will auto-generate an ephemeral token at startup.
# CONTROL_TOKEN=replace_with_strong_token

# Optional: cheaper model for subagent delegation (saves 40-60% tokens)
MODEL_SUBAGENT=

# Discord channel (optional — requires Bot Token from Discord Developer Portal)
# Enable Message Content Intent + Server Members Intent in bot settings
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=
